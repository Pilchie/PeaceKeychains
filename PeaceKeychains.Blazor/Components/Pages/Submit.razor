@page "/submit"
@using Azure.Storage.Blobs
@using Azure.Storage.Blobs.Models
@using Azure.Storage.Blobs.Specialized
@using ImageMagick
@using Microsoft.AspNetCore.Components.Forms
@using PeaceKeychains.Shared.Data
@using PeaceKeychains.Shared.Models
@inject PeaceKeychainsContext DbContext
@inject BlobServiceClient BlobClient
@inject NavigationManager Navigation
@inject ILogger<Submit> Logger

<PageTitle>Submit - Peace Keychains</PageTitle>

<div class="max-w-2xl mx-auto">
    <div class="text-center mb-8">
        <h1 class="text-3xl font-bold text-gray-800 mb-2">Share Your Story</h1>
        <p class="text-gray-600">Tell everyone about your Peace Keychain journey</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
        <form @onsubmit="HandleSubmit" @formname="submit-form" method="post" enctype="multipart/form-data">
            <AntiforgeryToken />
            
            @if (validationErrors.Count > 0)
            {
                <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl">
                    <div class="flex items-center mb-2">
                        <svg class="w-5 h-5 text-red-500 mr-2" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                        <span class="font-medium text-red-800">Please fix the following:</span>
                    </div>
                    <ul class="list-disc list-inside text-red-700 text-sm">
                        @foreach (var error in validationErrors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            }

            <div class="space-y-6">
                <!-- Title -->
                <div>
                    <label for="title" class="block text-sm font-medium text-gray-700 mb-2">Title *</label>
                    <input type="text" id="title" name="title" @bind="title"
                           class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-peace-500 focus:border-peace-500 transition-colors"
                           placeholder="Something catchy..." />
                </div>

                <!-- User -->
                <div>
                    <label for="user" class="block text-sm font-medium text-gray-700 mb-2">Your Name / Handle *</label>
                    <input type="text" id="user" name="user" @bind="user"
                           class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-peace-500 focus:border-peace-500 transition-colors"
                           placeholder="Email, Twitter, Instagram, or whatever you prefer" />
                </div>

                <!-- Text -->
                <div>
                    <label for="text" class="block text-sm font-medium text-gray-700 mb-2">Your Story</label>
                    <textarea id="text" name="text" @bind="text" rows="4"
                              class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:ring-2 focus:ring-peace-500 focus:border-peace-500 transition-colors resize-none"
                              placeholder="Tell everyone the story of how you got your Peace Keychain..."></textarea>
                </div>

                <!-- Image Upload -->
                <div>
                    <label for="image" class="block text-sm font-medium text-gray-700 mb-2">Image</label>
                    <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-xl hover:border-peace-400 transition-colors">
                        <div class="space-y-1 text-center">
                            <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                                <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                            </svg>
                            <div class="flex text-sm text-gray-600">
                                <label for="image" class="relative cursor-pointer rounded-md font-medium text-peace-600 hover:text-peace-500">
                                    <span>Upload a file</span>
                                    <InputFile id="image" name="image" OnChange="HandleFileSelected" class="sr-only" accept="image/*" />
                                </label>
                                <p class="pl-1">or drag and drop</p>
                            </div>
                            <p class="text-xs text-gray-500">PNG, JPG, GIF up to 10MB</p>
                            @if (!string.IsNullOrEmpty(selectedFileName))
                            {
                                <p class="text-sm text-peace-600 font-medium mt-2">Selected: @selectedFileName</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" disabled="@isSubmitting"
                        class="w-full py-4 px-6 bg-gradient-to-r from-peace-500 to-peace-600 text-white font-semibold rounded-xl shadow-lg hover:from-peace-600 hover:to-peace-700 transform hover:scale-[1.02] transition-all duration-200 disabled:opacity-50 disabled:cursor-not-allowed disabled:transform-none">
                    @if (isSubmitting)
                    {
                        <span class="flex items-center justify-center">
                            <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Submitting...
                        </span>
                    }
                    else
                    {
                        <span>Share Your Story ☮️</span>
                    }
                </button>
            </div>
        </form>

        <p class="mt-6 text-center text-sm text-gray-500">
            <svg class="w-4 h-4 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
            Note: There might be a delay before your submission appears while moderators review it.
        </p>
    </div>
</div>

@code {
    private string? title;
    private string? user;
    private string? text;
    private IBrowserFile? selectedFile;
    private string? selectedFileName;
    private List<string> validationErrors = new();
    private bool isSubmitting;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = e.File.Name;
    }

    private async Task HandleSubmit()
    {
        validationErrors.Clear();

        if (string.IsNullOrWhiteSpace(title))
            validationErrors.Add("Please provide a title");

        if (string.IsNullOrWhiteSpace(user))
            validationErrors.Add("Please provide your name or handle");

        if (string.IsNullOrWhiteSpace(text) && selectedFile is null)
            validationErrors.Add("Please provide either text or an image");

        if (validationErrors.Count > 0)
            return;

        isSubmitting = true;

        try
        {
            var now = DateTime.Now;
            var post = new Post(Guid.NewGuid(), now, title!, user!, text);

            if (selectedFile is not null)
            {
                Logger.LogInformation("Uploading image with FileName: {filename}, ContentType: {contentType}", 
                    selectedFile.Name, selectedFile.ContentType);

                var containerClient = BlobClient.GetBlobContainerClient("images");

                if (selectedFile.ContentType == "application/octet-stream" && 
                    Path.GetExtension(selectedFile.Name).Equals(".heic", StringComparison.OrdinalIgnoreCase))
                {
                    Logger.LogInformation("Converting image to jpg.");

                    var fileName = Path.ChangeExtension(selectedFile.Name, ".jpg");
                    var contentType = "image/jpeg";
                    var blockBlobClient = containerClient.GetBlockBlobClient($"{now:O}-{fileName}");

                    using var imageStream = selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                    using var memStream = new MemoryStream();
                    await imageStream.CopyToAsync(memStream);
                    memStream.Position = 0;

                    using var magickImage = new MagickImage(memStream);
                    magickImage.Format = MagickFormat.Jpeg;
                    var data = magickImage.ToByteArray();

                    using var convertedStream = new MemoryStream(data, false);
                    await blockBlobClient.UploadAsync(convertedStream);
                    await blockBlobClient.SetHttpHeadersAsync(new BlobHttpHeaders { ContentType = contentType });
                    post.OriginalImageUrl = blockBlobClient.Uri.AbsoluteUri;
                }
                else
                {
                    using var imageStream = selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                    var blockBlobClient = containerClient.GetBlockBlobClient($"{now:O}-{selectedFile.Name}");
                    await blockBlobClient.UploadAsync(imageStream);
                    await blockBlobClient.SetHttpHeadersAsync(new BlobHttpHeaders { ContentType = selectedFile.ContentType });
                    post.OriginalImageUrl = blockBlobClient.Uri.AbsoluteUri;
                }
            }

            post.Approved = true;
            DbContext.Posts.Add(post);
            await DbContext.SaveChangesAsync();

            Navigation.NavigateTo("/");
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
