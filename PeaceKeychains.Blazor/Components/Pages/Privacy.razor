@page "/privacy"

<PageTitle>Privacy Policy - Peace Keychains</PageTitle>

<div class="max-w-3xl mx-auto">
    <div class="bg-white rounded-2xl shadow-lg p-8 md:p-12">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-calm-100 rounded-full mb-4">
                <svg class="w-8 h-8 text-calm-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-gray-800">Privacy Policy</h1>
        </div>

        <div class="prose prose-lg max-w-none text-gray-600 space-y-6">
            <div class="bg-peace-50 border-l-4 border-peace-500 p-5 rounded-r-xl">
                <p class="text-gray-700 leading-relaxed">
                    By uploading pictures or stories, you grant Peace Keychains the right to display your content on our site.
                </p>
            </div>

            <h2 class="text-xl font-semibold text-gray-800 mt-8">What We Collect</h2>
            <p class="leading-relaxed">
                Beyond the pictures and text you upload, Peace Keychains 
                <span class="font-semibold text-peace-600">does not store any information about you</span>, 
                and does not share anything with any other companies.
            </p>

            <h2 class="text-xl font-semibold text-gray-800 mt-8">Copyright</h2>
            <p class="leading-relaxed">
                Please contact us if you are aware of any copyright issues in the content we display. 
                We take intellectual property rights seriously and will address any concerns promptly.
            </p>

            <div class="bg-gray-50 rounded-xl p-6 mt-8">
                <h3 class="text-lg font-semibold text-gray-800 mb-2 flex items-center">
                    <svg class="w-5 h-5 mr-2 text-calm-600" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
                        <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
                    </svg>
                    Questions?
                </h3>
                <p class="text-gray-600 text-sm">
                    If you have any questions about our privacy practices, feel free to reach out through our 
                    <a href="https://github.com/Pilchie/PeaceKeychains" target="_blank" rel="noopener noreferrer" 
                       class="text-calm-600 hover:text-calm-700 underline">GitHub repository</a>.
                </p>
            </div>
        </div>
    </div>
</div>
